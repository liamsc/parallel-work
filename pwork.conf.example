# parallel-work workspace configuration (reference)
# This file is auto-generated by p-init. You don't need to edit it manually.
# To set up a workspace:  p-init <repo-url> <workspace-path>
# To customize after setup: edit <workspace>/.parallel-work/pwork.conf

# ── Required ──────────────────────────────────────────────────
PWORK_REPO_URL="git@github.com:yourorg/yourrepo.git"
PWORK_REPO_SLUG="yourorg/yourrepo"          # for gh CLI (e.g. gh pr list --repo)
PWORK_CLONE_COUNT=5
PWORK_DEFAULT_BRANCH="main"

# ── Dependencies (optional) ──────────────────────────────────
# Command to run after git pull to sync dependencies.
# Examples:
#   "npm install"
#   "uv pip install -r requirements.txt"
#   "bundle install"
PWORK_SYNC_CMD=""

# ── Shared files (optional) ──────────────────────────────────
# Files to symlink from <workspace>/.shared/ into each clone.
# Format: "source_name:dest_name" — source is relative to .shared/,
# dest is relative to each clone root.
# The .shared/ directory is created automatically during install.
PWORK_SHARED_FILES=(
  # ".env_main:.env"
  # "config.yaml:config.yaml"
)

